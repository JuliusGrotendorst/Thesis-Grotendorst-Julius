# Make.com Webhook-URL (Pflicht)
# Anlegen unter: Make.com → Neues Szenario → Webhooks › Custom webhook
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/Ihre_URL_hier

# Optionaler Sicherheits-Header (empfohlen für Produktion)
# MAKE_WEBHOOK_SECRET=beliebiges-geheimes-token

# Google Drive Zielordner-ID (nur für scripts/uploadToDrive.js)
# GOOGLE_DRIVE_PARENT_FOLDER_ID=Ihre_Ordner_ID_hier
